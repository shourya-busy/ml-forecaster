# Copy to .env and tweak for your local run.

# --- core infra ---
DATABASE_URL=postgresql+psycopg://forecaster:forecaster@postgres:5432/forecaster
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
LOG_LEVEL=INFO
CELERY_CONCURRENCY=2

# --- runtime ---
FORECASTER_CONFIG_DIR=/app/config
ARTIFACT_DIR=/var/lib/forecaster/models
FORECASTER_USE_CUDA=0

# --- networking ---
# Name of the docker network your LGTM containers (prometheus, mimir, loki,
# tempo, grafana) share. Find it with:
#   docker inspect prometheus -f '{{range $net,$_ := .NetworkSettings.Networks}}{{$net}}{{println}}{{end}}'
# Default matches a typical `monitoring/docker-compose.yml` stack.
LGTM_NETWORK=monitoring_default

# --- ad-hoc overrides (FORECASTER__<SECTION>__<KEY>=<value>) ---
# FORECASTER__TRAINING__LOOKBACK_DAYS=14
# FORECASTER__DATA_SOURCES__ACTIVE=mimir_central
# FORECASTER__EXPOSITION__EMIT__PER_MODEL_FORECAST=false
