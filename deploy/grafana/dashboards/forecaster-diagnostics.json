{
  "annotations": {
    "list": []
  },
  "description": "Diagnostics for the multi-model forecaster: who's winning, who's runner-up, and how stable the ranking is.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "custom": {"align": "left", "displayMode": "auto", "inspect": false},
          "mappings": [],
          "thresholds": {"mode": "absolute", "steps": [{"color": "green"}]}
        },
        "overrides": []
      },
      "gridPos": {"h": 10, "w": 14, "x": 0, "y": 0},
      "id": 1,
      "options": {
        "showHeader": true
      },
      "pluginVersion": "10.4.0",
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "forecaster_winner",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ],
      "title": "Current winners",
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {"Time": true, "Value": true, "__name__": true, "job": true},
            "renameByName": {
              "instance": "Instance",
              "metric": "Metric",
              "horizon": "Horizon",
              "model": "Winning model"
            }
          }
        }
      ],
      "type": "table"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "description": "Number of distinct winners across the last K runs. 1 = stable, K = constantly flapping. Set by exposition.diagnostics.recent_window_runs.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 2},
              {"color": "red", "value": 4}
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {"h": 5, "w": 10, "x": 14, "y": 0},
      "id": 2,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "horizontal",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "value_and_name"
      },
      "pluginVersion": "10.4.0",
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "max(forecaster_winner_unique_recent{instance=~\"$instance\", metric=~\"$metric\", horizon=~\"$horizon\"})",
          "legendFormat": "{{instance}} {{metric}} {{horizon}}",
          "refId": "A"
        }
      ],
      "title": "Winner stability (lower is better)",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "description": "Backtest scores per algo, from the latest completed run for the selected target.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "mappings": [],
          "min": 0,
          "thresholds": {"mode": "absolute", "steps": [{"color": "blue"}]}
        },
        "overrides": []
      },
      "gridPos": {"h": 5, "w": 10, "x": 14, "y": 5},
      "id": 3,
      "options": {
        "displayMode": "gradient",
        "orientation": "horizontal",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "showUnfilled": true
      },
      "pluginVersion": "10.4.0",
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "forecast_model_score{instance=~\"$instance\", metric=~\"$metric\", horizon=~\"$horizon\", score=\"$score\"}",
          "legendFormat": "{{model}}",
          "refId": "A"
        }
      ],
      "title": "Score by model ($score) — latest run",
      "type": "bargauge"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "description": "How each algorithm's score has moved across retrains for the selected target. Watch for a model whose error is creeping up — that's drift.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "",
            "axisPlacement": "auto",
            "barAlignment": 0,
            "drawStyle": "line",
            "fillOpacity": 10,
            "gradientMode": "none",
            "hideFrom": {"legend": false, "tooltip": false, "viz": false},
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "pointSize": 5,
            "scaleDistribution": {"type": "linear"},
            "showPoints": "auto",
            "spanNulls": false,
            "stacking": {"group": "A", "mode": "none"},
            "thresholdsStyle": {"mode": "off"}
          },
          "mappings": []
        },
        "overrides": []
      },
      "gridPos": {"h": 11, "w": 24, "x": 0, "y": 10},
      "id": 4,
      "options": {
        "legend": {"calcs": [], "displayMode": "list", "placement": "bottom", "showLegend": true},
        "tooltip": {"mode": "multi", "sort": "none"}
      },
      "pluginVersion": "10.4.0",
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "forecast_model_score{instance=~\"$instance\", metric=~\"$metric\", horizon=~\"$horizon\", score=\"$score\"}",
          "legendFormat": "{{model}}",
          "refId": "A"
        }
      ],
      "title": "Score history per model — $score on $instance / $metric / $horizon",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
